{
	"name": "@xl0/show-sysprompt",
	"version": "0.1.0",
	"keywords": [
		"pi-package"
	],
	"type": "module",
	"license": "MIT",
	"files": ["extensions/", "README.md", "LICENSE"],
	"scripts": {
		"typecheck": "tsgo --noEmit",
		"check": "bun run typecheck && bun run biome:check",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"biome:check": "biome check ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@typescript/native-preview": "^7.0.0-dev.20260502.1",
		"bun-types": "^1.3.13",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"pi": {
		"extensions": [
			"./extensions"
		],
		"image": "https://raw.githubusercontent.com/xl0/pi-agent-show-sysprompt/main/screenshot.png",
		"video": "https://raw.githubusercontent.com/xl0/pi-agent-show-sysprompt/main/demo.mp4"
	}
}
